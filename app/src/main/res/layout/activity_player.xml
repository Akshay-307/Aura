<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ══ ExoPlayer Surface ══════════════════════════════════════════════ -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:resize_mode="fit" />

    <!-- ══ Buffering Indicator ════════════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/buffering_indicator"
        style="@style/Widget.AppCompat.ProgressBar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="#E50914"
        android:visibility="gone" />

    <!-- ══ Controls Overlay ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top gradient scrim -->
        <View
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_player_gradient_top" />

        <!-- Bottom gradient scrim -->
        <View
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_player_gradient_bottom" />

        <!-- ── TOP BAR ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_player_icon_btn"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"
                android:contentDescription="@string/content_description_back"
                android:padding="8dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tv_player_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4" />

            <!-- Sources button -->
            <Button
                android:id="@+id/btn_sources"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Sources"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_player_pill"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:visibility="gone" />

            <!-- Audio button -->
            <Button
                android:id="@+id/btn_audio"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Audio"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_player_pill"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone" />

            <!-- Speed button -->
            <Button
                android:id="@+id/btn_speed"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="1.0×"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_player_pill"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- Lock button -->
            <Button
                android:id="@+id/btn_lock"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/player_lock"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_player_pill"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- PiP button -->
            <Button
                android:id="@+id/btn_pip"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="PiP"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_player_pill"
                android:textSize="11sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

        <!-- ── CENTER CONTROLS ────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Rewind -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="8dp">

                <ImageButton
                    android:id="@+id/btn_rewind"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_rewind"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_player_icon_btn"
                    android:padding="14dp"
                    android:contentDescription="Rewind 10s" />

            </FrameLayout>

            <!-- Play/Pause — larger focal point -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp">

                <ImageButton
                    android:id="@+id/btn_play_pause"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_pause"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_player_icon_btn"
                    android:padding="18dp"
                    android:contentDescription="@string/content_description_play"
                    android:elevation="2dp" />

            </FrameLayout>

            <!-- Forward -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="8dp">

                <ImageButton
                    android:id="@+id/btn_forward"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_forward"
                    android:tint="#FFFFFF"
                    android:background="@drawable/bg_player_icon_btn"
                    android:padding="14dp"
                    android:contentDescription="Forward 10s" />

            </FrameLayout>

        </LinearLayout>

        <!-- ── BOTTOM BAR ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp"
            android:paddingTop="8dp">

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="11sp"
                    android:textColor="#CCFFFFFF"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="11sp"
                    android:textColor="#CCFFFFFF"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Seek bar -->
            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#E50914"
                android:progressBackgroundTint="#44FFFFFF"
                android:thumb="@drawable/ic_seek_thumb"
                android:thumbTint="#E50914"
                android:paddingStart="0dp"
                android:paddingEnd="0dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ══ Lock Overlay ══════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Centered lock indicator + unlock hint -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#CC000000"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Screen Locked — Tap to unlock"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
