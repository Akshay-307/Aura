<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Poster + Blur background -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="400dp">

                <!-- Blurred background -->
                <ImageView
                    android:id="@+id/iv_poster_blur"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null" />

                <!-- Dark overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/overlay_dark" />

                <!-- Back button — glassmorphic circle -->
                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_icon_circle"
                    android:src="@drawable/ic_arrow_back"
                    android:padding="9dp"
                    android:contentDescription="@string/content_description_back"
                    app:tint="@color/text_primary" />

                <!-- Centered poster -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="230dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/glass_stroke">

                    <ImageView
                        android:id="@+id/iv_poster"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/content_description_poster" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Progress indicator -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_margin="20dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <!-- Content Group -->
            <LinearLayout
                android:id="@+id/content_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/tv_detail_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tv_detail_genre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/primary_light"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_play"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/detail_play"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_btn_gradient"
                        android:layout_marginEnd="10dp"
                        app:icon="@drawable/ic_play"
                        app:iconSize="18dp"
                        app:iconTint="@color/text_primary"
                        app:backgroundTint="@null"
                        android:stateListAnimator="@null" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_watchlist"
                        style="@style/Widget.Aura.Button.Outline"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/detail_add_watchlist"
                        app:icon="@drawable/ic_add"
                        app:iconSize="16dp"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Synopsis"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="10dp" />

                <!-- TV Series Episodes Section -->
                <View
                    android:id="@+id/episodes_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="20dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_episodes_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Episodes"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/text_primary"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:id="@+id/seasons_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:visibility="gone">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/seasons_chip_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true" />
                </HorizontalScrollView>

                <LinearLayout
                    android:id="@+id/episodes_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

