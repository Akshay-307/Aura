<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070708">

    <!-- Glowing Background Graphic elements -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_centerInParent="true"
        android:background="@drawable/bg_splash_gradient"
        android:alpha="0.2" />

    <!-- Main Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Shield Icon & Header -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_check"
            app:tint="@color/primary"
            android:layout_marginBottom="16dp"
            android:contentDescription="Verification Shield" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SESSION SECURING"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please wait while we configure your secure streaming portal..."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="48dp"
            android:gravity="center" />

        <!-- Glowing Circular Progress Bar Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            app:cardBackgroundColor="#0D0D0F"
            app:cardElevation="8dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/primary"
            android:layout_marginBottom="32dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ProgressBar
                    android:id="@+id/loading_indicator"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/primary"
                    style="@style/Widget.AppCompat.ProgressBar" />
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Loading Status badge (pill style) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_player_pill"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/loading_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verifying connection…"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
